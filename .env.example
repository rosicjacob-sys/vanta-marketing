# Auth environment variables — set these in Netlify (Site configuration → Environment variables).
# All three are REQUIRED for login to work. Do NOT commit real values.

# Admin login email.
ADMIN_EMAIL=

# scrypt hash of the admin password (format: scrypt$<salt>$<hash>). The raw
# password is never stored. Generate a new one with netlify/lib/auth.mjs hashPassword().
ADMIN_PW_HASH=

# Random secret used to sign session tokens. Keep it private.
SESSION_SECRET=

# --- Optional ---

# Netlify DB (Postgres). Set automatically by Netlify when you add a database;
# until then the app runs on Netlify Blobs.
# NETLIFY_DATABASE_URL=

# Email (Resend). When set, notifications are also emailed. Verify a sending
# domain in Resend to email real clients (otherwise it only sends to your own
# address in test mode). EMAIL_FROM must use a verified domain.
RESEND_API_KEY=
EMAIL_FROM=Vanta <noreply@vantamarketing.io>

# Days before expiry to send the renewal reminder (daily cron). Default 3.
# REMINDER_LEAD_DAYS=3
