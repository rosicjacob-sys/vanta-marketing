# Auth environment variables — set these in Netlify (Site configuration → Environment variables).
# All three are REQUIRED for login to work. Do NOT commit real values.

# Admin login email.
ADMIN_EMAIL=

# scrypt hash of the admin password (format: scrypt$<salt>$<hash>). The raw
# password is never stored. Generate a new one with netlify/lib/auth.mjs hashPassword().
ADMIN_PW_HASH=

# Random secret used to sign session tokens. Keep it private.
SESSION_SECRET=
