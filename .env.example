# Environment variables for Vanta Marketing (Render).
# Set these in the Render dashboard under the "vanta-env" environment group.
# Do NOT commit real values. For local dev, copy to .env and load it.

# --- Required for login ---

# Admin login email.
ADMIN_EMAIL=

# scrypt hash of the admin password (format: scrypt$<salt>$<hash>). The raw
# password is never stored. Generate one with netlify/lib/auth.mjs hashPassword().
ADMIN_PW_HASH=

# Random secret used to sign session tokens. Keep it private.
SESSION_SECRET=

# --- Database (Neon Postgres) ---

# Neon connection string. The app reads this exact variable name (via
# @netlify/neon) - keep the name even though we're on Render now. Required.
NETLIFY_DATABASE_URL=

# --- netgrid API ---

NETGRID_API_URL=
NETGRID_API_KEY=

# --- Email (Resend) ---

# When set, notifications are also emailed. Verify a sending domain in Resend to
# email real clients. EMAIL_FROM must use a verified domain.
RESEND_API_KEY=
EMAIL_FROM=Vanta <noreply@vantamarketing.io>

# --- Optional ---

# Public site URL, used to build links in reminder emails.
URL=https://vantamarketing.io

# Days before expiry to send the renewal reminder (daily cron). Default 3.
REMINDER_LEAD_DAYS=3

# Port the server listens on. Render sets this automatically; default 3000 locally.
# PORT=3000
